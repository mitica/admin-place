{
  "name": "admin-place",
  "version": "0.0.0",
  "private": true,
  "description": "Structured country → admin division → locality geography data (GeoNames-modelled), stored as committed JSON and generated by TypeScript tooling.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "generate": "tsx src/generate.ts",
    "validate": "tsx src/validate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "node-stream-zip": "^1.15.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
